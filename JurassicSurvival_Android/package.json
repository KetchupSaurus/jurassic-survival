{
  "name": "jurassic-survival-android",
  "version": "1.0.0",
  "description": "Jurassic Survival – Android port via Capacitor",
  "scripts": {
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "sync": "npx cap sync android",
    "build": "npx cap build android",
    "install-apk": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "launch": "adb shell am start -n com.jurassicsurvival.game/.MainActivity",
    "logcat": "adb logcat -s chromium:D"
  },
  "_device": {
    "serial": "R92X308ZVHF",
    "model": "Samsung Galaxy Tab A9 (SM-X218U)",
    "android": "16",
    "sdk": "36",
    "screen": "1200x1920",
    "density": "240dpi"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1"
  }
}
